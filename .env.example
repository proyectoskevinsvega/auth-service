# ========================================
# AUTH SERVICE - ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env file with real credentials to git

# ========================================
# SERVER CONFIGURATION
# ========================================
HTTP_PORT=8082
GRPC_PORT=9092
LOG_LEVEL=info

# ENVIRONMENT: development | staging | production
# IMPORTANT: When set to "production", HTTPS is enforced and security headers include HSTS
ENVIRONMENT=development

# BASE_DOMAIN: Domain where the service is hosted
# Development: localhost:8080
# Production: auth.yourdomain.com (MUST be HTTPS, localhost not allowed)
BASE_DOMAIN=localhost:8080

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins
# Development: Include your frontend dev server (http://localhost:3000)
# Production: MUST use HTTPS (http:// not allowed except localhost)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ========================================
# PRODUCTION EXAMPLE (uncomment and modify)
# ========================================
# ENVIRONMENT=production
# BASE_DOMAIN=auth.yourdomain.com
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========================================
# DATABASE CONFIGURATION (PostgreSQL 14+)
# ========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_NAME=auth_service

# POSTGRES_SSLMODE: disable | require | verify-ca | verify-full
# Development: disable
# Production: require or verify-full (STRONGLY RECOMMENDED)
POSTGRES_SSLMODE=disable

# Connection Pool Settings
POSTGRES_MAX_CONNS=100
POSTGRES_MIN_CONNS=10
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_MAX_CONN_IDLE_TIME=30m
POSTGRES_MAX_CONNECTIONS=25
POSTGRES_MIN_CONNECTIONS=5

# ========================================
# REDIS CONFIGURATION (Redis 6+)
# ========================================
REDIS_CLUSTER_MODE=false
REDIS_HOST=localhost
REDIS_PORT=6379

# REDIS_PASSWORD: Empty for development, REQUIRED for production
REDIS_PASSWORD=

REDIS_DB=0
REDIS_POOL_SIZE=10

# ========================================
# JWT CONFIGURATION
# ========================================
# Generate RSA keys with: make generate-keys
# Keys should be 2048-bit minimum, 4096-bit recommended for production
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem

# JWT_ISSUER: Your auth service domain
# Should match BASE_DOMAIN in production
JWT_ISSUER=localhost:8080

# Expiration Settings
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7


# ========================================
# RATE LIMITING CONFIGURATION
# ========================================
# Login Rate Limiting
RATE_LIMIT_LOGIN_ATTEMPTS=5           # Max attempts
RATE_LIMIT_LOGIN_WINDOW=60            # Time window in seconds
RATE_LIMIT_LOGIN_BLOCK_DURATION=3600  # Block duration in seconds (1 hour)

# Registration Rate Limiting
RATE_LIMIT_REGISTER_ATTEMPTS=3        # Max attempts
RATE_LIMIT_REGISTER_WINDOW=3600       # Time window in seconds (1 hour)

# Token Refresh Rate Limiting
RATE_LIMIT_REFRESH_ATTEMPTS=10        # Max attempts
RATE_LIMIT_REFRESH_WINDOW=60          # Time window in seconds

# ========================================
# EMAIL CONFIGURATION (Resend API)
# ========================================
# EMAIL_ENABLED: Set to false to disable email sending (useful for development)
EMAIL_ENABLED=false

# RESEND_API_KEY: Get your API key from https://resend.com/api-keys
# Format: re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxxx

# EMAIL_FROM: Sender email (must be verified domain in Resend)
# Production: Use your verified domain email
EMAIL_FROM=noreply@yourdomain.com

# EMAIL_FROM_NAME: Display name for sender
EMAIL_FROM_NAME=Your App Name

# ========================================
# SECURITY POLICIES (P0/P2)
# ========================================
SESSION_INACTIVITY_DAYS=30

# Account Lockout (Brute force protection)
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_BASE_DURATION_MINS=5
LOCKOUT_ESCALATION_FACTOR=3.0
LOCKOUT_MAX_DURATION_DAYS=1

# Password Policies
PASSWORD_EXPIRY_DAYS=90
PASSWORD_EXPIRY_WARNING_DAYS=7

# ========================================
# OAUTH CONFIGURATION
# ========================================

# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/google/callback

# GitHub OAuth
# Get credentials from: https://github.com/settings/developers
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/github/callback

# ========================================
# GEOLOCATION (Optional - MaxMind GeoIP2)
# ========================================
# Enables IP-based geolocation for login tracking
GEOLOCATION_ENABLED=false

# Get license key from: https://www.maxmind.com/en/geolite2/signup
MAXMIND_LICENSE_KEY=

# Path to MaxMind GeoLite2 database file
MAXMIND_DB_PATH=./data/GeoLite2-Country.mmdb

# ========================================
# WEBAUTHN (Passkeys / Biometrics)
# ========================================
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_DISPLAY_NAME=VerterCloud
# Origins must include protocol and port if not standard
WEBAUTHN_RP_ORIGINS=http://localhost:8080,https://localhost:8080

# ========================================
# THREAT INTELLIGENCE (AbuseIPDB)
# ========================================
THREAT_INTEL_ENABLED=false
THREAT_INTEL_PROVIDER=abuseipdb
THREAT_INTEL_API_KEY=
THREAT_INTEL_BLOCK_THRESHOLD=80
THREAT_INTEL_MFA_THRESHOLD=40

# ========================================
# INTERNAL SERVICES (gRPC)
# ========================================
# Authentication is handled via mTLS (Mutual TLS)

# gRPC mTLS (Mutual TLS)
# When enabled, clients MUST provide a certificate signed by the GRPC_CA_CERT
GRPC_TLS_ENABLED=false
GRPC_CA_CERT_PATH=./keys/ca.pem
GRPC_SERVER_CERT_PATH=./keys/server.pem
GRPC_SERVER_KEY_PATH=./keys/server-key.pem

# ========================================
# NOTIFICATIONS (Redis Queue)
# ========================================
NOTIFICATIONS_ENABLED=false
NOTIFICATION_REDIS_QUEUE=notify:queue

# ========================================
# TELEMETRY (OpenTelemetry Distributed Tracing)
# ========================================
# Enable to trace requests across services
TELEMETRY_ENABLED=false
TELEMETRY_SERVICE_NAME=auth-service
TELEMETRY_SERVICE_VERSION=1.0.0
TELEMETRY_ENVIRONMENT=development

# Exporter Type: jaeger | otlp | stdout
# - jaeger: Send to Jaeger collector (development)
# - otlp: Send to OpenTelemetry Collector (production)
# - stdout: Print to console (debugging)
TELEMETRY_EXPORTER_TYPE=jaeger

# Jaeger Configuration (development)
TELEMETRY_JAEGER_ENDPOINT=http://localhost:14268/api/traces

# OTLP Configuration (production)
TELEMETRY_OTLP_ENDPOINT=localhost:4317
TELEMETRY_OTLP_INSECURE=true

# Sampling Rate: 0.0 to 1.0 (0.1 = 10%, 1.0 = 100%)
# Development: 1.0 (trace everything)
# Production: 0.1 or less (trace 10% to reduce overhead)
TELEMETRY_SAMPLING_RATE=1.0

# Feature Flags: Enable/disable tracing per component
TELEMETRY_TRACE_HTTP=true
TELEMETRY_TRACE_GRPC=true
TELEMETRY_TRACE_DATABASE=true
TELEMETRY_TRACE_REDIS=true


RESEND_API_KEY=
APP_NAME=
EMAIL_FROM=
EMAIL_FROM_NAME=
