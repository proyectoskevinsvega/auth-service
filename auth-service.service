# sudo systemctl daemon-reload
# sudo systemctl enable auth-service
# sudo systemctl start auth-service
# sudo systemctl status auth-service
# sudo journalctl -u auth-service -f

[Unit]
Description=Auth Service — auth.bravexcolombia.com
Documentation=https://github.com/proyectoskevinsvega/auth-service
After=network.target redis.service postgresql.service
Wants=network-online.target

[Service]
LimitNOFILE=65535
Type=simple
User=ubuntu
Group=ubuntu

WorkingDirectory=/home/ubuntu/backend-vertercloud/auth-service
ExecStart=/home/ubuntu/backend-vertercloud/auth-service/bin/auth-service

# El binario lee las env vars desde el EnvironmentFile

EnvironmentFile=-/home/ubuntu/backend-vertercloud/auth-service/.env

ExecStop=/bin/kill -SIGTERM $MAINPID

Restart=on-failure
RestartSec=5s
StartLimitIntervalSec=60
StartLimitBurst=3

StandardOutput=journal
StandardError=journal
SyslogIdentifier=auth-service

PrivateTmp=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
